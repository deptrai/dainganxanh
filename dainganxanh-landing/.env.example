# Supabase Configuration
# Copy this file to .env.local and fill in your Supabase project details

# Get these from: https://supabase.com/dashboard/project/gzuuyzikjvykjpeixzqk/settings/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://gzuuyzikjvykjpeixzqk.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Story 5-2: Casso Webhook Integration
# Get from: Casso dashboard → Settings → Webhook → Security Key
CASSO_SECURE_TOKEN=your_casso_secure_token_here
# Get from: Casso dashboard → Settings → API key (for querying historical transactions)
CASSO_API_KEY=your_casso_api_key_here

# Telegram Notifications
# Tạo bot qua @BotFather, thêm bot vào group, lấy chat_id bằng @getidsbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_group_chat_id_here

# Camera Streaming (go2rtc)
NEXT_PUBLIC_GO2RTC_URL=http://167.172.66.16:1984

# Story 1-6: Banking Payment (Casso)
# MB Bank account for Casso auto-confirm
NEXT_PUBLIC_BANK_NAME=MB Bank
NEXT_PUBLIC_BANK_ACCOUNT=796333999
NEXT_PUBLIC_BANK_HOLDER=CONG TY CO PHAN DAI NGAN XANH GROUP
NEXT_PUBLIC_BANK_BRANCH=TP HCM

# Story 10-2: Contract Generation (LibreOffice headless — no external API needed)
# Install: brew install --cask libreoffice (macOS) | apt install libreoffice (Linux/Docker)
# Override binary path if needed (default: macOS app bundle or 'soffice' on Linux)
# SOFFICE_BIN=/usr/bin/soffice

# Story 10-2: Internal API key for contract generation endpoint
# Generate a random string: openssl rand -hex 32
CONTRACT_API_SECRET=your_contract_api_secret_here
