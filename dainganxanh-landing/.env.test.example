# E2E test environment overrides
# Copy to .env.test (gitignored) and fill in real local values.

# Admin account for admin-flow E2E tests. Must exist in test DB with
# admin/super_admin role and have a Mailpit-routable inbox.
TEST_ADMIN_EMAIL=admin@test.local

# Regular-user account. Falls back to TEST_ADMIN_EMAIL if unset.
TEST_USER_EMAIL=user@test.local

# Mailpit endpoint for OTP retrieval. Default matches dev compose.
MAILPIT_URL=http://127.0.0.1:54334
